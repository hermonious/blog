---
import { siteConfig } from "@/config/site";
---

<footer class="px-4 pb-8 pt-12 sm:px-6 lg:px-8">
  <div class="shell-card mx-auto flex max-w-6xl flex-col gap-4 rounded-[2rem] px-6 py-6 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="font-sans text-lg font-semibold text-[var(--ink-strong)]">{siteConfig.name}</p>
      <p class="mt-2 max-w-xl text-sm leading-7 text-[var(--ink-muted)]">
        {siteConfig.description}
      </p>
    </div>
    <div class="text-right text-sm text-[var(--ink-muted)]">
      <p>Powered by Astro + MDX + Tailwind</p>
      <p class="mt-1">部署目标：GitHub Pages</p>
      <div class="mt-3 flex flex-wrap justify-end gap-3">
        {siteConfig.socialLinks.map((link) => (
          <a class="text-[var(--accent)] no-underline transition hover:opacity-70" href={link.href}>
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
