---
import TagPill from "./TagPill.astro";
import { estimateReadingTime, formatDate, type BlogPost } from "@/utils/blog";
import { withBase } from "@/utils/links";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const readingTime = estimateReadingTime(post.body ?? "");
const postHref = withBase(`posts/${post.id}/`);
---

<article class="shell-card group rounded-[1.75rem] p-6 transition duration-300 hover:-translate-y-1 hover:bg-[var(--surface-strong)]">
  <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-[var(--ink-muted)]">
    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    <span>·</span>
    <span>{readingTime} 分钟阅读</span>
  </div>

  <h2 class="mt-4 text-2xl font-semibold tracking-tight text-[var(--ink-strong)]">
    <a class="no-underline" href={postHref}>
      {post.data.title}
    </a>
  </h2>

  <p class="mt-3 leading-7 text-[var(--ink-muted)]">{post.data.description}</p>

  <div class="mt-5 flex flex-wrap gap-2">
    {post.data.tags.map((tag) => <TagPill tag={tag} />)}
  </div>

  <div class="mt-6 flex items-center justify-between">
    <a
      class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--accent)] no-underline transition group-hover:translate-x-1"
      href={postHref}
    >
      阅读全文
      <span aria-hidden="true">→</span>
    </a>
    {post.data.featured && (
      <span class="rounded-full bg-[var(--accent-soft)] px-3 py-1 text-xs font-semibold text-[var(--accent)]">
        Featured
      </span>
    )}
  </div>
</article>
