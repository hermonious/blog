---
import { getCollection } from "astro:content";
import MainLayout from "@/layouts/MainLayout.astro";
import { formatDate, getSortedPosts, groupPostsByYear } from "@/utils/blog";
import { withBase } from "@/utils/links";

const posts = getSortedPosts(await getCollection("blog"));
const groups = groupPostsByYear(posts);
---

<MainLayout title="归档" description="按年份查看博客里的全部文章。">
  <section class="px-4 pb-8 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="eyebrow text-xs font-semibold text-[var(--accent)]">Archive</p>
      <h1 class="mt-3 font-sans text-4xl font-bold tracking-tight text-[var(--ink-strong)]">归档</h1>
      <div class="mt-8 space-y-8">
        {groups.map((group) => (
          <section class="shell-card rounded-[2rem] p-6 sm:p-8">
            <div class="flex items-end justify-between gap-4">
              <h2 class="font-sans text-3xl font-semibold tracking-tight text-[var(--ink-strong)]">
                {group.year}
              </h2>
              <span class="text-sm text-[var(--ink-muted)]">{group.posts.length} 篇</span>
            </div>

            <ul class="mt-6 space-y-4">
              {group.posts.map((post) => (
                <li class="rounded-[1.5rem] border border-[var(--border-soft)] bg-white/45 px-4 py-4">
                  <a
                    class="flex flex-col gap-2 no-underline transition sm:flex-row sm:items-center sm:justify-between"
                    href={withBase(`posts/${post.id}/`)}
                  >
                    <span class="font-sans text-xl font-semibold text-[var(--ink-strong)]">
                      {post.data.title}
                    </span>
                    <time class="text-sm text-[var(--ink-muted)]" datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
