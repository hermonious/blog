---
import MainLayout from "@/layouts/MainLayout.astro";
import { withBase } from "@/utils/links";

const homeHref = withBase();
const postsHref = withBase("posts/");
---

<MainLayout title="页面不存在" description="你访问的页面没有找到。">
  <section class="px-4 pb-10 pt-16 sm:px-6 lg:px-8">
    <div class="shell-card mx-auto max-w-3xl rounded-[2.5rem] px-6 py-10 text-center sm:px-10">
      <p class="eyebrow text-xs font-semibold text-[var(--accent)]">404</p>
      <h1 class="mt-4 font-sans text-4xl font-bold tracking-tight text-[var(--ink-strong)]">
        这页好像漂到别处去了
      </h1>
      <p class="mt-4 text-lg leading-8 text-[var(--ink-muted)]">
        你可以回到首页重新开始，或者去文章列表看看最近的内容。
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          class="inline-flex items-center rounded-full bg-[var(--accent)] px-5 py-3 text-sm font-semibold text-white no-underline"
          href={homeHref}
        >
          返回首页
        </a>
        <a
          class="inline-flex items-center rounded-full border border-[var(--border-soft)] bg-white/70 px-5 py-3 text-sm font-semibold text-[var(--ink-strong)] no-underline"
          href={postsHref}
        >
          查看文章
        </a>
      </div>
    </div>
  </section>
</MainLayout>
