---
import { getCollection } from "astro:content";
import MainLayout from "@/layouts/MainLayout.astro";
import { getSortedPosts, getTagCounts } from "@/utils/blog";
import { withBase } from "@/utils/links";

const posts = getSortedPosts(await getCollection("blog"));
const tags = getTagCounts(posts);
---

<MainLayout title="标签" description="按标签浏览博客内容。">
  <section class="px-4 pb-8 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="eyebrow text-xs font-semibold text-[var(--accent)]">Topics</p>
      <h1 class="mt-3 font-sans text-4xl font-bold tracking-tight text-[var(--ink-strong)]">标签</h1>
      <p class="mt-4 max-w-2xl text-lg leading-8 text-[var(--ink-muted)]">
        这里不是把文章机械分类，而是把长期会反复出现的话题组织成一个可浏览的入口。
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {tags.map(({ tag, count }) => (
          <a
            class="shell-card rounded-[1.6rem] p-5 no-underline transition hover:-translate-y-1 hover:bg-[var(--surface-strong)]"
            href={withBase(`tags/${encodeURIComponent(tag)}/`)}
          >
            <p class="font-sans text-2xl font-semibold tracking-tight text-[var(--ink-strong)]">
              #{tag}
            </p>
            <p class="mt-2 text-sm text-[var(--ink-muted)]">{count} 篇文章</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
