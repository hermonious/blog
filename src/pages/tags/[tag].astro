---
import { getCollection } from "astro:content";
import MainLayout from "@/layouts/MainLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { getAllTags, getSortedPosts, type BlogPost } from "@/utils/blog";

export async function getStaticPaths() {
  const posts = getSortedPosts(await getCollection("blog"));

  return getAllTags(posts).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.includes(tag))
    }
  }));
}

interface Props {
  tag: string;
  posts: BlogPost[];
}

const { tag, posts } = Astro.props;
---

<MainLayout title={`标签：${tag}`} description={`查看与 ${tag} 相关的所有文章。`}>
  <section class="px-4 pb-8 pt-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow text-xs font-semibold text-[var(--accent)]">Tag Archive</p>
      <h1 class="mt-3 font-sans text-4xl font-bold tracking-tight text-[var(--ink-strong)]">
        #{tag}
      </h1>
      <p class="mt-4 text-lg leading-8 text-[var(--ink-muted)]">这里共有 {posts.length} 篇相关内容。</p>

      <div class="mt-8 grid gap-5 lg:grid-cols-2">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</MainLayout>
